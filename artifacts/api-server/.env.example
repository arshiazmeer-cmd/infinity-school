# Email (SMTP) Configuration
# Copy these to Replit Secrets — never commit real values here.

SMTP_HOST=smtp.gmail.com        # e.g. smtp.gmail.com for Gmail, smtp.zoho.com for Zoho
SMTP_PORT=587                   # 587 for TLS (recommended), 465 for SSL
SMTP_USER=your_email@gmail.com  # The email address used to send emails
SMTP_PASS=your_app_password     # Gmail: use an App Password (not your login password)
ADMIN_EMAIL=ipskursi@gmail.com  # School admin email — receives all admission notifications
